generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String        @id @default(cuid())
  email      String        @unique
  username   String        @unique
  password   String
  name       String?
  role       String        @default("editor")
  status     String        @default("active")
  articles   Article[]
  activities ActivityLog[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([role, status])
}

model Province {
  slug        String   @id
  code        String?  @unique
  type        String?
  label       String
  description String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cities      City[]
  stores      Store[]

  @@index([isActive])
  @@index([isActive, order])
}

model City {
  slug         String   @id
  code         String?  @unique
  type         String?
  provinceSlug String
  province     Province @relation(fields: [provinceSlug], references: [slug], onDelete: Cascade)
  label        String
  description  String?
  imageUrl     String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  stores       Store[]

  @@index([provinceSlug])
  @@index([isActive])
}

model Store {
  id              String           @id @default(cuid())
  name            String
  slug            String?          @unique
  level           StoreLevel       @default(flagship)
  provinceSlug    String
  province        Province         @relation(fields: [provinceSlug], references: [slug], onDelete: Restrict)
  provinceLabel   String
  citySlug        String
  city            City             @relation(fields: [citySlug], references: [slug], onDelete: Restrict)
  cityLabel       String
  district        String?
  address         String
  phone           String
  phoneTel        String
  businessHours   String?
  description     String?
  imageUrl        String?
  imagePath       String?
  status          String           @default("pending")
  statusReason    String?
  statusChangedAt DateTime?
  statusChangedBy String?
  isActive        Boolean          @default(true)
  events          AnalyticsEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([provinceSlug])
  @@index([citySlug])
  @@index([isActive])
  @@index([status])
  @@index([slug])
  @@index([isActive, provinceSlug])
  @@index([status, provinceSlug])
  @@index([level])
  @@index([level, status])
}

enum StoreLevel {
  flagship
  premium
  specialty
  member
}

model Article {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  featuredImage String?
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  status        String    @default("draft")
  category      String?
  tags          String[]  @default([])
  viewCount     Int       @default(0)
  isSticky      Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
  @@index([status, publishedAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  pathname  String
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  metadata  Json?
  userAgent String?
  ip        String?
  timestamp DateTime @default(now())

  @@index([type])
  @@index([storeId])
  @@index([pathname])
  @@index([timestamp])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([createdAt])
  @@map("activity_logs")
}
